# Gemini (builder AI) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Vapi (voice platform) — https://dashboard.vapi.ai/org/api-keys
VAPI_API_KEY=your_vapi_private_api_key

# Vapi public key — same dashboard page, safe to expose in the browser.
# Used client-side to start web calls with @vapi-ai/web.
NEXT_PUBLIC_VAPI_API_KEY=your_vapi_public_api_key

# Cal.com (meeting booking) — https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=your_cal_api_key
